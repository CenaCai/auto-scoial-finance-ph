# 环境变量示例 — 复制为 .env 并填写

# ── 新闻采集 ──
SERPER_API_KEY=your_serper_api_key_here

# ── AI 改写 ──
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Sheets ──
GOOGLE_CREDENTIALS_PATH=./credentials.json
CONTENT_CALENDAR_SHEET_KEY=your_google_sheet_key_here

# ── 代理 IP（每个账号固定 IP）──
# 格式：http://user:pass@proxy:port
PROXY_ADVISOR=http://user:pass@proxy1.example.com:8080
PROXY_WORKER=http://user:pass@proxy2.example.com:8080
PROXY_EDUCATOR=http://user:pass@proxy3.example.com:8080

# ── Cookie 存储 ──
COOKIE_DIR=./data/cookies
